Date: Fri, 17 Apr 2026 12:54:23 +0200
Subject: [PATCH] Fixed appdata descriptions

I accidentally put them at the same level as the release tags.


(cherry picked from commit 99bd17a2044919aa91fc5d200e55365d06614e58)

Co-authored-by: Jack Hill <jackhill3103@gmail.com>
---
 ktorrent/org.kde.ktorrent.appdata.xml | 94 ++++++++++++++-------------
 1 file changed, 50 insertions(+), 44 deletions(-)

diff --git a/ktorrent/org.kde.ktorrent.appdata.xml b/ktorrent/org.kde.ktorrent.appdata.xml
index 1fa1bbee9..7aedf2753 100644
--- a/ktorrent/org.kde.ktorrent.appdata.xml
+++ b/ktorrent/org.kde.ktorrent.appdata.xml
@@ -987,25 +987,27 @@
     <release version="25.12.3" date="2026-03-05"/>
     <release version="25.12.2" date="2026-02-05"/>
     <release version="25.12.1" date="2026-01-08"/>
-    <release version="25.12.0" date="2025-12-11"/>
-    <description>
-      <ul>
-        <li>Fixed a bug causing the magnets file to be constantly updated</li>
-        <li>Fixed the progress bar highlight color</li>
-        <li>Fixed the log viewer settings tooltip showing raw HTML</li>
-      </ul>
-    </description>
+    <release version="25.12.0" date="2025-12-11">
+      <description>
+        <ul>
+          <li>Fixed a bug causing the magnets file to be constantly updated</li>
+          <li>Fixed the progress bar highlight color</li>
+          <li>Fixed the log viewer settings tooltip showing raw HTML</li>
+        </ul>
+      </description>
+    </release>
     <release version="25.08.3" date="2025-11-06"/>
     <release version="25.08.2" date="2025-10-09"/>
     <release version="25.08.1" date="2025-09-11"/>
-    <release version="25.08.0" date="2025-08-14"/>
-    <description>
-      <ul>
-        <li>Added a "Last Activity" column showing the time the torrent last had upload or download activity</li>
-        <li>Fixed the background color of the syndication widget's feed-item status panel</li>
-        <li>Added columns to the main view showing the number of bytes uploaded and downloaded in the current session</li>
-      </ul>
-    </description>
+    <release version="25.08.0" date="2025-08-14">
+      <description>
+        <ul>
+          <li>Added a "Last Activity" column showing the time the torrent last had upload or download activity</li>
+          <li>Fixed the background color of the syndication widget's feed-item status panel</li>
+          <li>Added columns to the main view showing the number of bytes uploaded and downloaded in the current session</li>
+        </ul>
+      </description>
+    </release>
     <release version="25.04.3" date="2025-07-03"/>
     <release version="25.04.2" date="2025-06-05"/>
     <release version="25.04.1" date="2025-05-08"/>
@@ -1013,38 +1015,42 @@
     <release version="24.12.3" date="2025-03-06"/>
     <release version="24.12.2" date="2025-02-06"/>
     <release version="24.12.1" date="2025-01-09"/>
-    <release version="24.12.0" date="2024-12-12"/>
-    <description>
-      <ul>
-        <li>The "Added" column now uses a shorter date format</li>
-        <li>Fixed a crash when closing the video widget</li>
-      </ul>
-    </description>
-    <release version="24.08.3" date="2024-11-07"/>
-    <description>
-      <ul>
-        <li>Accept webseeds using HTTPS</li>
-        <li>Fixed charts having white text on a white background in the Statistics plugin</li>
-      </ul>
-    </description>
-    <release version="24.08.2" date="2024-10-10"/>
-    <description>
-      <ul>
-        <li>Fixed the Import Torrent dialog not allowing .torrent files to be selected</li>
-      </ul>
-    </description>
+    <release version="24.12.0" date="2024-12-12">
+      <description>
+        <ul>
+          <li>The "Added" column now uses a shorter date format</li>
+          <li>Fixed a crash when closing the video widget</li>
+        </ul>
+      </description>
+    </release>
+    <release version="24.08.3" date="2024-11-07">
+      <description>
+        <ul>
+          <li>Accept webseeds using HTTPS</li>
+          <li>Fixed charts having white text on a white background in the Statistics plugin</li>
+        </ul>
+      </description>
+    </release>
+    <release version="24.08.2" date="2024-10-10">
+      <description>
+        <ul>
+          <li>Fixed the Import Torrent dialog not allowing .torrent files to be selected</li>
+        </ul>
+      </description>
+    </release>
     <release version="24.08.1" date="2024-09-12"/>
     <release version="24.08.0" date="2024-08-22"/>
     <release version="24.05.2" date="2024-07-04"/>
     <release version="24.05.1" date="2024-06-13"/>
-    <release version="24.05.0" date="2024-05-23"/>
-    <description>
-      <ul>
-        <li>Added an action to rename files in the Info Widget context menu</li>
-        <li>Save the magnets file whenever it is updated, so that magnet data is not lost if the app crashes</li>
-        <li>Use a different icon for queued seeding and queued downloading</li>
-      </ul>
-    </description>
+    <release version="24.05.0" date="2024-05-23">
+      <description>
+        <ul>
+          <li>Added an action to rename files in the Info Widget context menu</li>
+          <li>Save the magnets file whenever it is updated, so that magnet data is not lost if the app crashes</li>
+          <li>Use a different icon for queued seeding and queued downloading</li>
+        </ul>
+      </description>
+    </release>
     <release version="24.02.2" date="2024-04-11"/>
     <release version="24.02.1" date="2024-03-21"/>
     <release version="24.02.0" date="2024-02-28">
